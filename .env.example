# ============================================================================
# ContractIQ — Environment Variables
#
# Next.js vars (NEXT_PUBLIC_* and any without a SERVER ONLY tag consumed by
# the app itself) go in `.env.local` at the project root, copied from this file.
#
# Vars tagged SERVER ONLY / Edge Function are never placed in `.env.local`.
# They are set as Supabase secrets instead:
#   supabase secrets set OPENAI_API_KEY=sk-...
# and are read inside `supabase/functions/*` via `Deno.env.get(...)`.
# ============================================================================

# --- Supabase — Next.js client ----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=              # Supabase project URL — Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Supabase anon/public key — Settings > API

# --- Supabase — server / Edge Functions -------------------------------------
SUPABASE_SERVICE_ROLE_KEY=             # SERVER ONLY. Settings > API. Two legitimate uses: (1) supabase/functions/retention-cleanup, which must operate across all users, bypassing RLS; (2) contractiq/lib/supabase/admin.ts, used only by lib/security/rateLimiter.ts to read/write rate_limit_events. Never used anywhere else, never sent to the client.
CRON_SECRET=                           # SERVER ONLY. Set as a Supabase secret and referenced by supabase/retention-cleanup-cron.sql's net.http_post call. Shared secret so supabase/functions/retention-cleanup only accepts internal pg_cron invocations, never public requests.

# --- OpenAI — Edge Functions only -------------------------------------------
OPENAI_API_KEY=                        # SERVER ONLY. platform.openai.com/api-keys. Set as a Supabase secret (`supabase secrets set OPENAI_API_KEY=...`). Read inside upload-extract-text, process-contract, and chat-message. Never touches Vercel or the browser.

# --- App config — Next.js ----------------------------------------------------
NEXT_PUBLIC_APP_URL=                   # e.g. http://localhost:3001 (dev) or https://contractiq.app (prod) — used to build Supabase Auth email-confirmation redirect URLs
MAX_CHAT_HISTORY=200                   # Max prior chat messages sent as model context per turn. Matches the PRD's 200-message ceiling (docs/specs/06-contract-chat-spec.md) — do not lower to the generic default of 100 without updating that spec too.
